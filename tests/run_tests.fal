// Tests for the falcon/log library.
// Verifies that each log level produces output on stdout.
import "../../testing/testing.fal";
import "../../strings/strings.fal";
import "../../io/io.fal";
import "../log.fal";

// ─────────────────────────────────────────────────────────────────────────────
// Suite: Log level output
//
// The spdlog-backed log library writes formatted records to stdout.
// We capture stdout around each call and assert the expected level tag and
// message text appear in the output.
// ─────────────────────────────────────────────────────────────────────────────
autotuner LogOutputTests -> (int passed, int failed) {
    passed = 0; failed = 0;
    start -> __init;

    // ── Info ──────────────────────────────────────────────────────────────────
    state test_info_appears_on_stdout (TestRunner runner, TestContext t) {
        Error err     = io::BeginStdout();
        err           = log::Info("test-info-message");
        string out    = io::End();
        string plain  = strings::StripAnsi(out);
        bool has_msg  = strings::Contains(plain, "test-info-message");
        err           = t.ExpectTrue(has_msg, "Info: message present on stdout");
        -> __end(runner, t);
    }

    state test_info_level_tag (TestRunner runner, TestContext t) {
        Error err      = io::BeginStdout();
        err            = log::Info("level-tag-info");
        string out     = io::End();
        string plain   = strings::StripAnsi(out);
        // spdlog formats level as [info] or similar
        bool has_level = strings::Contains(plain, "info");
        err            = t.ExpectTrue(has_level, "Info: level tag present in output");
        -> __end(runner, t);
    }

    // ── Debug ─────────────────────────────────────────────────────────────────
    state test_debug_appears_on_stdout (TestRunner runner, TestContext t) {
        Error err     = io::BeginStdout();
        err           = log::Debug("test-debug-message");
        string out    = io::End();
        string plain  = strings::StripAnsi(out);
        bool has_msg  = strings::Contains(plain, "test-debug-message");
        err           = t.ExpectTrue(has_msg, "Debug: message present on stdout");
        -> __end(runner, t);
    }

    state test_debug_level_tag (TestRunner runner, TestContext t) {
        Error err      = io::BeginStdout();
        err            = log::Debug("level-tag-debug");
        string out     = io::End();
        string plain   = strings::StripAnsi(out);
        bool has_level = strings::Contains(plain, "debug");
        err            = t.ExpectTrue(has_level, "Debug: level tag present in output");
        -> __end(runner, t);
    }

    // ── Warn ──────────────────────────────────────────────────────────────────
    state test_warn_appears_on_stdout (TestRunner runner, TestContext t) {
        Error err     = io::BeginStdout();
        err           = log::Warn("test-warn-message");
        string out    = io::End();
        string plain  = strings::StripAnsi(out);
        bool has_msg  = strings::Contains(plain, "test-warn-message");
        err           = t.ExpectTrue(has_msg, "Warn: message present on stdout");
        -> __end(runner, t);
    }

    state test_warn_level_tag (TestRunner runner, TestContext t) {
        Error err      = io::BeginStdout();
        err            = log::Warn("level-tag-warn");
        string out     = io::End();
        string plain   = strings::StripAnsi(out);
        bool has_level = strings::Contains(plain, "warn");
        err            = t.ExpectTrue(has_level, "Warn: level tag present in output");
        -> __end(runner, t);
    }

    // ── Error ────────────────────────────────────────────���────────────────────
    state test_error_appears_on_stdout (TestRunner runner, TestContext t) {
        Error err     = io::BeginStdout();
        err           = log::Err("test-error-message");
        string out    = io::End();
        string plain  = strings::StripAnsi(out);
        bool has_msg  = strings::Contains(plain, "test-error-message");
        err           = t.ExpectTrue(has_msg, "Error: message present on stdout");
        -> __end(runner, t);
    }

    state test_error_level_tag (TestRunner runner, TestContext t) {
        Error err      = io::BeginStdout();
        err            = log::Err("level-tag-error");
        string out     = io::End();
        string plain   = strings::StripAnsi(out);
        bool has_level = strings::Contains(plain, "error");
        err            = t.ExpectTrue(has_level, "Error: level tag present in output");
        -> __end(runner, t);
    }

    // ── Cross-level isolation ─────────────────────────────────────────────────
    state test_messages_are_distinct (TestRunner runner, TestContext t) {
        Error err       = io::BeginStdout();
        err             = log::Info("unique-info-xyz");
        string out      = io::End();
        string plain    = strings::StripAnsi(out);
        bool no_debug   = strings::Contains(plain, "unique-debug-xyz");
        err             = t.ExpectFalse(no_debug, "Info call does not emit debug text");
        -> __end(runner, t);
    }
}
